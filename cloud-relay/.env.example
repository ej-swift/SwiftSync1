# Port the relay listens on (Railway/Fly set PORT automatically)
PORT=8080

# Public URL users see in QR codes — no trailing slash
# Example: https://relay.yourdomain.com
PUBLIC_URL=https://relay.yourdomain.com

# Optional: protect /api/admin/* endpoints
ADMIN_TOKEN=change-me-to-a-long-random-string

# SwiftSync-owned EulerStream account (TikTok live chat JWT proxy)
# Get these from eulerstream.com Dashboard after signing up once for SwiftSync
EULER_API_KEY=
EULER_ACCOUNT_ID=

# ── OAuth secrets (server-side exchange — users need ZERO dev-app setup) ───────
# Store these with: fly secrets set TWITCH_CLIENT_ID=... TWITCH_CLIENT_SECRET=...
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Local deploy only — run setup-fly-auth.ps1 once; do not commit the real token
# FLY_API_TOKEN=FlyV1_...

# Path to mobile UI static files (Docker sets this; dev uses ../pc-app)
# MOBILE_ROOT=../pc-app
